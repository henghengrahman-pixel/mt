<section class="slider" data-slider>
  <div class="slider-track" data-slider-track>
    <% if (sliders && sliders.length) { %>
      <% sliders.forEach(function(slide, index){ %>
        <a class="slide <%= index === 0 ? 'is-active' : '' %>" href="<%= slide.link || '#' %>">
          <img src="<%= slide.imageUrl %>" alt="<%= slide.title || 'Slide' %>" loading="<%= index === 0 ? 'eager' : 'lazy' %>">
        </a>
      <% }) %>
    <% } else { %>
      <div class="empty-slide">MASUK ADMIN UNTUK SET SLIDE FOTO</div>
    <% } %>
  </div>
  <% if (sliders && sliders.length > 1) { %>
    <div class="slider-dots" data-slider-dots>
      <% sliders.forEach(function(slide, index){ %><button class="<%= index === 0 ? 'active' : '' %>" type="button" data-dot="<%= index %>"></button><% }) %>
    </div>
  <% } %>
</section>
