<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-page">
  <aside class="sidebar">
    <h2>ADMIN</h2>
    <a href="/pinktiger8008">Dashboard</a>
    <a href="/pinktiger8008/settings">Pengaturan</a>
    <a class="active" href="/pinktiger8008/sliders">Slider Foto</a>
    <a href="/" target="_blank">Lihat Website</a>
    <form method="post" action="/pinktiger8008/logout"><button>Logout</button></form>
  </aside>
  <main class="admin-main">
    <h1>Slider Foto</h1>
    <% if (saved) { %><div class="alert success">Slider berhasil disimpan.</div><% } %>
    <form class="panel form-panel" method="post" action="/pinktiger8008/sliders">
      <p class="muted">Masukkan gambar banner pakai link. Bisa tambah banyak slide.</p>
      <div id="sliderArea" class="rows-editor">
        <% (sliders && sliders.length ? sliders : [{title:'',imageUrl:'',link:'#',order:1,active:true}]).forEach(function(slide, i){ %>
          <div class="edit-row slider-row">
            <input name="title" value="<%= slide.title || '' %>" placeholder="Judul slide">
            <input name="imageUrl" value="<%= slide.imageUrl || '' %>" placeholder="URL gambar banner">
            <input name="link" value="<%= slide.link || '#' %>" placeholder="Link ketika diklik">
            <input name="order" type="number" value="<%= slide.order || i + 1 %>" placeholder="Urutan">
            <label class="check"><input type="checkbox" name="active" value="<%= i %>" <%= slide.active !== false ? 'checked' : '' %>> Aktif</label>
          </div>
        <% }) %>
      </div>
      <button type="button" class="secondary" onclick="addSliderRow()">+ Tambah Slide</button>
      <button class="save-btn" type="submit">SIMPAN SLIDER</button>
    </form>
  </main>
  <script>
    function addSliderRow(){
      const area = document.getElementById('sliderArea');
      const i = area.children.length;
      const div = document.createElement('div');
      div.className = 'edit-row slider-row';
      div.innerHTML = `<input name="title" placeholder="Judul slide"><input name="imageUrl" placeholder="URL gambar banner"><input name="link" placeholder="Link ketika diklik" value="#"><input name="order" type="number" value="${i + 1}"><label class="check"><input type="checkbox" name="active" value="${i}" checked> Aktif</label>`;
      area.appendChild(div);
    }
  </script>
</body>
</html>
